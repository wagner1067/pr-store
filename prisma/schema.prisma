datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ═══════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════

enum Role {
  DONO
  GERENTE
  FUNCIONARIO
}

enum PaymentMethod {
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  BOLETO
  PROMISSORIA
}

enum ShippingMethod {
  CORREIOS
  MOTO_FRETE
  RETIRADA
}

enum OrderStatus {
  PENDENTE
  PAGO
  ENVIADO
  ENTREGUE
  CANCELADO
}

enum ExpenseCategory {
  FIXO
  VARIAVEL
}

// ═══════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════

model Usuario {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String   @unique
  password  String   // BCrypt hash
  role      Role     @default(FUNCIONARIO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendasPresenciais Venda[] @relation("Vendedor")

  @@index([email])
  @@index([role])
}

model Cliente {
  id        String   @id @default(uuid())
  name      String?
  phone     String   @unique
  email     String?
  createdAt DateTime @default(now())

  pedidos      Pedido[]
  promissorias Promissoria[]

  @@index([phone])
  @@index([createdAt])
}

model Produto {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String
  price       Float
  promoPrice  Float?
  promoUntil  DateTime?
  category    String
  brand       String
  sizes       String[]
  images      String[]
  stock       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  itensPedido ItemPedido[]

  @@index([category, brand])
  @@index([slug])
  @@index([category])
  @@index([brand])
  @@index([isActive, createdAt])
  @@index([stock])
}

model Pedido {
  id             String         @id @default(uuid())
  clienteId      String
  total          Float
  status         OrderStatus    @default(PENDENTE)
  paymentMethod  PaymentMethod
  shippingMethod ShippingMethod
  shippingCost   Float          @default(0.0)
  stripeSessionId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  cliente Cliente      @relation(fields: [clienteId], references: [id])
  itens   ItemPedido[]

  @@index([clienteId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentMethod])
}

model ItemPedido {
  id        String @id @default(uuid())
  pedidoId  String
  produtoId String
  quantity  Int
  price     Float
  size      String?

  pedido  Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id])

  @@index([pedidoId])
  @@index([produtoId])
}

model Venda {
  id            String        @id @default(uuid())
  vendedorId    String?
  total         Float
  paymentMethod PaymentMethod
  isPresencial  Boolean       @default(false)
  createdAt     DateTime      @default(now())

  vendedor Usuario? @relation("Vendedor", fields: [vendedorId], references: [id])

  @@index([createdAt])
  @@index([isPresencial])
  @@index([paymentMethod])
  @@index([vendedorId])
}

model Promissoria {
  id         String   @id @default(uuid())
  clienteId  String
  totalDebt  Float
  dueDate    DateTime
  isOverdue  Boolean  @default(false)
  isPaid     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([dueDate])
  @@index([isOverdue])
  @@index([isPaid])
}

model RegistroCaixa {
  id          String    @id @default(uuid())
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  initialAmt  Float
  finalAmt    Float?
  isBalanced  Boolean   @default(false)
  notes       String?

  despesas Despesa[]

  @@index([openedAt])
}

model Despesa {
  id          String          @id @default(uuid())
  description String
  value       Float
  category    ExpenseCategory @default(VARIAVEL)
  caixaId     String?
  createdAt   DateTime        @default(now())

  caixa RegistroCaixa? @relation(fields: [caixaId], references: [id])

  @@index([createdAt])
  @@index([category])
}
